NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Empty means browser requests same-origin /api/* and Next rewrites proxy to FRONTEND_API_BASE_URL.
NEXT_PUBLIC_API_URL=
# Used only while prerendering static article pages in CI/Docker/local builds.
BUILD_API_BASE_URL=https://api.panyakorn.com
# Use http://backend:8888 in Docker on the VPS. Use https://api.panyakorn.com for local development.
FRONTEND_API_BASE_URL=https://api.panyakorn.com
PORTFOLIO_API_TIMEOUT_MS=3000
