{
  "name": "portfolio",
  "version": "0.1.54",
  "private": true,
  "packageManager": "bun@1.3.14",
  "overrides": {
    "postcss": "^8.5.15"
  },
  "scripts": {
    "dev": "next dev",
    "dev:live-api": "NEXT_PUBLIC_SITE_URL=http://localhost:3000 NEXT_PUBLIC_API_URL= FRONTEND_API_BASE_URL=https://api.panyakorn.com BUILD_API_BASE_URL=https://api.panyakorn.com next dev",
    "build": "next build",
    "start": "next start",
    "env:check": "node scripts/check-env.mjs",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "bun test",
    "verify": "bun run test && bun run lint && bun run build",
    "hooks:install": "command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "prepare": "bun run hooks:install",
    "doctor": "bunx react-doctor@latest",
    "deploy:prepare": "bun run env:check && bun run build"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.9",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "react-doctor": "^0.5.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
