{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "overrides": {
    "postcss": "^8.5.15"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "env:check": "node scripts/check-env.mjs",
    "lint": "biome check .",
    "format": "biome format --write .",
    "doctor": "pnpm dlx react-doctor@latest",
    "db:start": "prisma dev -d -n portfolio",
    "db:status": "prisma dev ls",
    "db:stop": "prisma dev stop portfolio",
    "db:sync": "prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "deploy:prepare": "pnpm env:check && pnpm prisma:generate && pnpm db:migrate:deploy && pnpm build",
    "db:seed:articles": "node scripts/seed-articles.mjs",
    "auth:create-admin": "node scripts/create-admin-user.mjs --role admin",
    "auth:create-user": "node scripts/create-admin-user.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "clsx": "^2.1.1",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "lighthouse": "^13.4.0",
    "prisma": "^7.8.0",
    "react-doctor": "^0.5.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
